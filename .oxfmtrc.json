{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"arrowParens": "always",
	"bracketSameLine": true,
	"bracketSpacing": true,
	"endOfLine": "lf",
	"ignorePatterns": [
		".astro/**/*",
		".wrangler/",
		"bun.lock",
		"dist/**/*",
		"node_modules/**/*",
		"pnpm-lock.yaml",
		"worker-configuration.d.ts"
	],
	"jsxSingleQuote": true,
	"printWidth": 90,
	"semi": true,
	"singleAttributePerLine": true,
	"singleQuote": true,
	"sortImports": {
		"groups": [
			"builtin",
			"external",
			["internal", "subpath"],
			["parent", "sibling", "index"],
			"unknown"
		],
		"internalPattern": ["~/*", "@/*"],
		"newlinesBetween": true,
		"order": "asc"
	},
	"sortPackageJson": true,
	"sortTailwindcss": {
		"functions": ["clsx", "cn", "cva", "tw"]
	},
	"tabWidth": 4,
	"trailingComma": "all",
	"useTabs": true
}
